# Server configuration
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/quran_db

# CORS — comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000

# Public URL of this API. Used as the `servers` entry in the OpenAPI doc
# so Scalar/Swagger UI generate correct "try it" requests in production.
# If unset, defaults to http://localhost:${PORT}.
API_URL=http://localhost:5000

# APIs (only needed for --semanticRoots seed script)
GEMINI_API_KEY=your_gemini_api_key_here

# API Key authentication
API_KEY_PEPPER=your-generated-32-char-hex-string-minimum-32-characters
API_KEY_HEADER=X-API-Key
