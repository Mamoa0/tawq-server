{
  "name": "quarn-test",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts,json --exec tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed:surahs": "node --loader ts-node/esm src/scripts/index.ts --surahs",
    "seed:verses": "node --loader ts-node/esm src/scripts/index.ts --verses",
    "seed:words": "node --loader ts-node/esm src/scripts/index.ts --words",
    "seed:tokens": "node --loader ts-node/esm src/scripts/index.ts --tokens",
    "seed:roots": "node --loader ts-node/esm src/scripts/index.ts --roots",
    "seed:all": "npm run seed:surahs && npm run seed:verses && npm run seed:words && npm run seed:tokens && npm run seed:roots && npm run seed:verify",
    "seed:verify": "node --loader ts-node/esm src/scripts/index.ts --verify",
    "seed:semanticRoots": "node --loader ts-node/esm src/scripts/index.ts --semanticRoots",
    "db:clear": "node --loader ts-node/esm src/scripts/index.ts --clear",
    "db:reset": "npm run db:clear && npm run seed:all",
    "convert": "node convert.js",
    "keys:create": "node --loader ts-node/esm src/scripts/keys/create.ts",
    "keys:revoke": "node --loader ts-node/esm src/scripts/keys/revoke.ts"
  },
  "type": "module",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.4.3",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@scalar/fastify-api-reference": "^1.46.4",
    "@types/pdf-parse": "^1.1.5",
    "dotenv": "^17.3.1",
    "fastify": "^5.8.1",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "^1.1.10",
    "mongoose": "^8.23.0",
    "openapi3-ts": "^4.5.0",
    "pdf-parse": "^2.4.5",
    "quran-meta": "^6.0.17",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@octokit/rest": "^20.0.2",
    "@types/node": "^25.3.5",
    "@vitest/ui": "^3.0.5",
    "mongodb-memory-server": "^10.0.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^3.0.5",
    "yaml": "^2.8.3"
  }
}
